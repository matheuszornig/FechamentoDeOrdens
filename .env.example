# --- Banco (Neon Postgres) ---------------------------------------------------
# Injetada automaticamente pela integração Neon <-> Vercel (branch por preview).
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Better Auth --------------------------------------------------------------
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=troque-por-um-segredo-forte
# URL pública do app (na Vercel: https://seu-app.vercel.app)
BETTER_AUTH_URL=http://localhost:3000

# --- API BTG Pactual ----------------------------------------------------------
BTG_API_URL=https://api.btgpactual.com
BTG_CLIENT_ID=
BTG_CLIENT_SECRET=
# true em Preview (usa notas fictícias determinísticas), false em Production
BTG_USE_MOCK=true

# --- Seed do usuário admin (workflow seed.yml / pnpm seed:admin) ---------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=troque-esta-senha
